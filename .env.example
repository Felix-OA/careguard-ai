# No key is needed for the default deterministic local workflow.
CAREGUARD_DATA_DIR=/data
CAREGUARD_DEMO_URL=http://demo-agent:8001
CAREGUARD_GUARD_URL=http://careguard-guard:8002
CAREGUARD_GUARD_MODE=enforce
CAREGUARD_GUARD_CONFIG=/app/configs/careguard-guard.example.yaml

# Optional authorized OpenAI-compatible local endpoint only.
OPENAI_COMPATIBLE_ENDPOINT=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_API_KEY=
